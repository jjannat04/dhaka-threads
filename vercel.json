{
  "version": 2,
  "builds": [
    {
      "src": "cloth_store/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
    },
    {
  "src": "build_files.sh",
  "use": "@vercel/static-build",
  "config": { "distDir": "staticfiles_build/static" }
}
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "cloth_store/wsgi.py"
    }
  ]
}